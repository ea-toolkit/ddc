{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-entity.sh"
          }
        ],
        "description": "Validate entity type field matches target directory before writing"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/anonymization-guard.sh"
          }
        ],
        "description": "Block writes containing real (non-anonymized) names in public knowledge base files"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-commit.sh"
          }
        ],
        "description": "Auto-commit domain-knowledge and cycle-log changes (DDC principle: commit early, commit often)"
      }
    ]
  }
}